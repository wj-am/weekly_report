<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>个人周报 - 汪吉</title>
  <style>
    :root {
      --primary: #4F46E5;
      --primary-light: #EEF2FF;
      --secondary: #06B6D4;
      --secondary-light: #ECFEFF;
      --accent: #F59E0B;
      --accent-light: #FFFBEB;
      --success: #10B981;
      --success-light: #ECFDF5;
      --purple: #7C3AED;
      --purple-light: #F5F3FF;
      --danger: #EF4444;
      --danger-light: #FEF2F2;
      --text-main: #1E293B;
      --text-sub: #64748B;
      --border: #E2E8F0;
      --bg: #F1F5F9;
      --card: #FFFFFF;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
      background: var(--bg);
      color: var(--text-main);
      line-height: 1.75;
    }

    /* ── Header ── */
    .site-header {
      background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 55%, #06B6D4 100%);
      color: white;
      padding: 48px 24px 40px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .site-header::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 220px; height: 220px;
      border-radius: 50%;
      background: rgba(255,255,255,0.07);
      pointer-events: none;
    }
    .site-header::after {
      content: '';
      position: absolute;
      bottom: -80px; left: -40px;
      width: 260px; height: 260px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
      pointer-events: none;
    }
    .site-header h1 {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: 1px;
      position: relative;
      z-index: 1;
    }
    .header-meta {
      margin-top: 8px;
      font-size: 13px;
      opacity: 0.75;
      position: relative;
      z-index: 1;
    }
    .badge-row {
      margin-top: 20px;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px;
      position: relative;
      z-index: 1;
    }
    .badge {
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.3);
      border-radius: 20px;
      padding: 5px 16px;
      font-size: 13px;
      font-weight: 500;
      backdrop-filter: blur(4px);
    }

    /* ── Tab Nav ── */
    .tab-nav {
      display: flex;
      justify-content: center;
      gap: 0;
      background: var(--card);
      border-bottom: 2px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .tab-btn {
      padding: 16px 36px;
      border: none;
      background: transparent;
      font-size: 15px;
      font-weight: 600;
      color: var(--text-sub);
      cursor: pointer;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      transition: color 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .tab-btn.active {
      color: var(--primary);
      border-bottom-color: var(--primary);
    }
    .tab-btn:hover:not(.active) {
      color: var(--text-main);
    }

    /* ── Tab Panels ── */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Layout ── */
    .container {
      max-width: 960px;
      margin: 0 auto;
      padding: 32px 20px 60px;
    }

    /* ── Section Title ── */
    .section-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-main);
      margin: 36px 0 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section-title::before {
      content: '';
      display: inline-block;
      width: 4px;
      height: 20px;
      border-radius: 2px;
      background: var(--primary);
      flex-shrink: 0;
    }

    /* ── Card ── */
    .card {
      background: var(--card);
      border-radius: 14px;
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
      border: 1px solid var(--border);
    }

    /* ── Work Item ── */
    .work-item {
      background: var(--card);
      border-radius: 14px;
      padding: 24px 28px;
      margin-bottom: 18px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
      border: 1px solid var(--border);
      border-left: 4px solid var(--primary);
    }
    .work-item:nth-child(2) { border-left-color: var(--secondary); }
    .work-item:nth-child(3) { border-left-color: var(--accent); }
    .work-item:nth-child(4) { border-left-color: var(--success); }
    .work-item:nth-child(5) { border-left-color: var(--purple); }
    .work-item-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 10px;
      color: var(--text-main);
    }
    .work-item-body {
      font-size: 14px;
      color: var(--text-sub);
      line-height: 1.8;
    }

    /* ── Table ── */
    .table-wrap {
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid var(--border);
      margin-bottom: 20px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
    }
    thead tr {
      background: linear-gradient(90deg, var(--primary) 0%, var(--purple) 100%);
      color: white;
    }
    thead th {
      padding: 12px 14px;
      text-align: center;
      font-weight: 600;
      white-space: nowrap;
    }
    tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--primary-light); }
    tbody td {
      padding: 11px 14px;
      text-align: center;
      color: var(--text-main);
      white-space: nowrap;
    }
    tbody td:nth-child(2) { text-align: left; }
    .tag-wechat {
      display: inline-block;
      background: var(--success-light);
      color: var(--success);
      border-radius: 6px;
      padding: 2px 10px;
      font-size: 12px;
      font-weight: 600;
    }
    .tag-sms {
      display: inline-block;
      background: var(--secondary-light);
      color: var(--secondary);
      border-radius: 6px;
      padding: 2px 10px;
      font-size: 12px;
      font-weight: 600;
    }
    .highlight-best td { background: #FFFBEB !important; font-weight: 600; }

    /* ── Analysis Cards ── */
    .analysis-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 20px;
    }
    @media (max-width: 640px) {
      .analysis-grid { grid-template-columns: 1fr; }
      .tab-btn { padding: 14px 18px; font-size: 13px; }
    }
    .analysis-card {
      background: var(--card);
      border-radius: 12px;
      padding: 20px;
      border: 1px solid var(--border);
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .analysis-card-title {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 14px;
      color: var(--text-main);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .analysis-card-title .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--primary);
      flex-shrink: 0;
    }
    .analysis-card-title .dot.green { background: var(--success); }
    .analysis-card-title .dot.amber { background: var(--accent); }
    .analysis-card-title .dot.red { background: var(--danger); }
    .analysis-card-title .dot.purple { background: var(--purple); }

    /* Bar chart rows */
    .bar-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 13px;
    }
    .bar-label { width: 130px; flex-shrink: 0; color: var(--text-sub); font-size: 12px; }
    .bar-track {
      flex: 1;
      background: var(--bg);
      border-radius: 6px;
      height: 10px;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      border-radius: 6px;
      background: linear-gradient(90deg, var(--primary), var(--purple));
    }
    .bar-fill.green { background: linear-gradient(90deg, var(--success), #34D399); }
    .bar-fill.amber { background: linear-gradient(90deg, var(--accent), #FCD34D); }
    .bar-fill.red   { background: linear-gradient(90deg, var(--danger), #FCA5A5); }
    .bar-fill.cyan  { background: linear-gradient(90deg, var(--secondary), #67E8F9); }
    .bar-val { width: 48px; text-align: right; font-weight: 600; font-size: 12px; color: var(--text-main); }

    /* Insight list */
    .insight-list { list-style: none; }
    .insight-list li {
      padding: 8px 0;
      border-bottom: 1px dashed var(--border);
      font-size: 13px;
      color: var(--text-sub);
      display: flex;
      gap: 8px;
      align-items: flex-start;
    }
    .insight-list li:last-child { border-bottom: none; }
    .insight-list li .icon { flex-shrink: 0; margin-top: 2px; }

    /* KPI summary row */
    .kpi-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 20px;
    }
    @media (max-width: 640px) { .kpi-row { grid-template-columns: repeat(2, 1fr); } }
    .kpi-card {
      background: var(--card);
      border-radius: 12px;
      padding: 18px 14px;
      border: 1px solid var(--border);
      text-align: center;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .kpi-val {
      font-size: 22px;
      font-weight: 800;
      color: var(--primary);
      line-height: 1.2;
    }
    .kpi-val.green { color: var(--success); }
    .kpi-val.amber { color: var(--accent); }
    .kpi-val.purple { color: var(--purple); }
    .kpi-label {
      font-size: 12px;
      color: var(--text-sub);
      margin-top: 4px;
    }

    /* Plan items */
    .plan-item {
      background: var(--card);
      border-radius: 14px;
      padding: 22px 26px;
      margin-bottom: 16px;
      border: 1px solid var(--border);
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .plan-item-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }
    .plan-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .plan-icon.blue   { background: var(--primary-light); }
    .plan-icon.green  { background: var(--success-light); }
    .plan-icon.amber  { background: var(--accent-light); }
    .plan-icon.purple { background: var(--purple-light); }
    .plan-icon.cyan   { background: var(--secondary-light); }
    .plan-title {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-main);
    }
    .plan-priority {
      margin-left: auto;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 12px;
    }
    .plan-priority.high { background: var(--danger-light); color: var(--danger); }
    .plan-priority.mid  { background: var(--accent-light); color: var(--accent); }
    .plan-priority.low  { background: var(--success-light); color: var(--success); }
    .plan-body { font-size: 13.5px; color: var(--text-sub); line-height: 1.8; }
    .plan-sub {
      margin-top: 10px;
      padding-left: 12px;
      border-left: 3px solid var(--border);
    }
    .plan-sub p {
      font-size: 13px;
      color: var(--text-sub);
      margin-bottom: 4px;
    }
    .plan-sub strong { color: var(--text-main); }

    /* full-width analysis card */
    .analysis-card-full {
      background: var(--card);
      border-radius: 12px;
      padding: 20px;
      border: 1px solid var(--border);
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      margin-bottom: 20px;
    }
  </style>
</head>
